---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - {siteConfig.title}</title>

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${siteConfig.name} - ${siteConfig.title}`} />
    <meta property="og:description" content={siteConfig.description} />
    {Astro.site && <meta property="og:image" content={new URL('/og.png', Astro.site).href} />}
    {Astro.site && <meta property="og:url" content={Astro.site.href} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${siteConfig.name} - ${siteConfig.title}`} />
    <meta name="twitter:description" content={siteConfig.description} />
    {Astro.site && <meta name="twitter:image" content={new URL('/og.png', Astro.site).href} />}

    <!-- SEO -->
    <meta name="keywords" content="Daniel Almendrades, logística internacional, freight forwarder, agencia marítima, shipping Perú, transporte de carga internacional, SEA Cargo, executive director, supply chain, comercio internacional, bilingüe español inglés, Lima Perú" />
    <link rel="canonical" href="https://daniel-almendrades.cofoundy.dev/" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": siteConfig.name,
      "jobTitle": siteConfig.title,
      "url": "https://daniel-almendrades.cofoundy.dev/",
      "worksFor": {
        "@type": "Organization",
        "name": "SEA Cargo Logistics Perú SAC",
        "url": "https://www.seacargo.com.pe"
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "California Coast University" },
        { "@type": "CollegeOrUniversity", "name": "Instituto Tecnológico de Monterrey" },
        { "@type": "CollegeOrUniversity", "name": "British Columbia Institute of Technology" }
      ],
      "address": { "@type": "PostalAddress", "addressLocality": "Lima", "addressCountry": "PE" },
      "nationality": ["Peruvian", "Canadian"],
      "knowsLanguage": ["Spanish", "English"],
      "sameAs": [siteConfig.social.linkedin]
    })} />
  </head>
  <body>
    <Header />
    <main>
      <Hero />
      <About />
      <Projects />
      <Experience />
      <Education />
    </main>
    <Footer />

    <script>
      // Scroll reveal observer
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
      );
      document.querySelectorAll(".reveal, .reveal-left, .reveal-right, .reveal-scale").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
